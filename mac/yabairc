#!/usr/bin/env sh
# yabai config — ported from the Sway/i3 rice (github.com/mosschief/rice).
#
# IMPORTANT: this runs WITHOUT the scripting addition (SIP stays enabled), so
# yabai manages window *tiling within each native macOS Space*. Per-monitor
# Space switching is handled by Hammerspoon + iss-cli; keybinds by skhd.
# Operations that need the scripting addition (create/move Spaces, send window
# to another Space) are intentionally not used here.

# ---- layout ----
yabai -m config layout                       bsp

# Sway: gaps inner 4  -> gap between windows.
# Widened to 10 so the 4px JankyBorders on adjacent windows aren't clipped.
yabai -m config window_gap                    10
# Sway: gaps outer 0 -> bumped to 8 so borders aren't cut off at screen edges.
yabai -m config top_padding                   8
yabai -m config bottom_padding                8
yabai -m config left_padding                  8
yabai -m config right_padding                 8

# Reserve space for the sketchybar ONLY on the built-in display (main:28:0);
# the external displays have no bar and no reserved gap (windows use full height).
yabai -m config external_bar                  main:28:0

# New windows split the focused container (i3/Sway-like behavior)
yabai -m config window_placement              second_child
yabai -m config split_ratio                   0.50
yabai -m config auto_balance                  off

# Sway: focus_follows_mouse no
yabai -m config focus_follows_mouse           off
yabai -m config mouse_follows_focus           off

# Sway: floating_modifier Mod1 (alt) — drag/resize floating windows with alt held
yabai -m config mouse_modifier                alt
yabai -m config mouse_action1                 move
yabai -m config mouse_action2                 resize
# drop a window onto another to swap them
yabai -m config mouse_drop_action             swap

# ---- float windows that shouldn't be tiled ----
yabai -m rule --add app="^System Settings$"            manage=off
yabai -m rule --add app="^System Information$"         manage=off
yabai -m rule --add app="^Karabiner-Elements$"         manage=off
yabai -m rule --add app="^Hammerspoon$"                manage=off
yabai -m rule --add app="^Finder$" title="^(Copy|Move|Delete|Info|Get Info)$" manage=off
yabai -m rule --add app="^(Calculator|System Preferences|Archive Utility)$"    manage=off

echo "yabai configuration loaded"
